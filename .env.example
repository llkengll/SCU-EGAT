# SCU Web App - Environment Configuration
# Copy this to .env and adjust values for each computer

# Node.js / Express Backend
PORT=3000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key

# React Frontend
VITE_API_BASE_URL=http://localhost/api

# Database (PostgreSQL)
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=scu_db
DB_HOST=localhost
DB_PORT=5432

# MinIO (S3)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=scu-data

# Machine Learning Server (Flask)
ML_SERVER_HOST=localhost
ML_SERVER_PORT=5000
ML_SERVER_URL=http://localhost:5000
ML_API_KEY=your_ml_api_auth_key

# Server IPs (Change these for the 3-server setup)
COMP_1_IP=127.0.0.1
COMP_2_IP=127.0.0.1
COMP_3_IP=127.0.0.1
